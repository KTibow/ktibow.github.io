---
import BlogPost from '$lib/layouts/BlogPost.astro';
import Route from './_Route.astro';
import Percent from './_Percent.astro';
import Pulser from './_Pulser.astro';
import redactedScript from '@fontsource/redacted-script/files/redacted-script-latin-400-normal.woff2';
import '@fontsource/redacted-script/latin-400.css';
import obaLogo from './oba-logo.svg';
import stopData from './1_10912.json';
import tripUpdates1 from './1.pbtext?raw';
import tripUpdates40 from './40.pbtext?raw';

export const title = "Fixing Sound Transit's ETAs";
export const date = '2026-07-03';

const anchorTime = new Date('Fri Jul  3 01:42:33 PM PDT 2026');
const relativeTime = (date: Date) => {
  const seconds = (date.getTime() - anchorTime.getTime()) / 1000;
  const magnitude = Math.abs(seconds);
  const magnitudeRound = Math.round(magnitude);
  const str = magnitudeRound >= 100 ? `${Math.round(magnitude / 60)}m` : `${magnitudeRound}s`;
  return seconds >= 0 ? `in ${str}` : `${str} ago`;
};

const arrivalsAndDepartures = stopData.data.entry.arrivalsAndDepartures.filter(
  (ad) => ad.routeId.startsWith('1_') || ad.routeId.startsWith('40_'),
);
const jn = arrivalsAndDepartures.length;
const jnPredicted = arrivalsAndDepartures.filter((ad) => ad.predicted).length;
const jnPredictedAndMidway = arrivalsAndDepartures.filter(
  (ad) =>
    ad.predicted && ad.tripStatus.lastLocationUpdateTime && ad.tripStatus.activeTripId == ad.tripId,
).length;
const jnPredictedAndLocation = arrivalsAndDepartures.filter(
  (ad) => ad.predicted && ad.tripStatus.lastLocationUpdateTime,
).length;
const jnPredictedAndLocationAndSoon = arrivalsAndDepartures.filter(
  (ad) =>
    ad.predicted &&
    ad.tripStatus.lastLocationUpdateTime &&
    ad.predictedArrivalTime < anchorTime.getTime() + 1000 * 60 * 60,
).length;
const jnPredictedMeaningfully = arrivalsAndDepartures.filter(
  (ad) => ad.predicted && ad.predictedArrivalTime != ad.scheduledArrivalTime,
).length;

// Step 1: Isolate each full entity block safely (No lag, anchors to start of line)
const entities: RegExpExecArray[] = [];
entities.push(...tripUpdates1.matchAll(/^entity \{([\s\S]*?)\n\}/gm));
entities.push(...tripUpdates40.matchAll(/^entity \{([\s\S]*?)\n\}/gm));

const tripUpdatesParsed = entities.map((entityMatch, index) => {
  const entityBlock = entityMatch[1];

  // Step 2: Precise Mega-Regexes using line-start (m flag) and exact spacing
  const entityId = entityBlock.match(/^  id: "([^"]+)"$/m)?.[1] || null;
  const tripId = entityBlock.match(/^      trip_id: "([^"]+)"$/m)?.[1] || null;
  const relationship = entityBlock.match(/^      schedule_relationship: ([A-Z_]+)$/m)?.[1] || null;
  const routeId = entityBlock.match(/^      route_id: "([^"]+)"$/m)?.[1];
  const vehicleId = entityBlock.match(/^    vehicle \{\n\s+id: "([^"]+)"\n\s+\}$/m)?.[1] || null;
  const timestamp = entityBlock.match(/^    timestamp: (\d+)$/m)![1];
  const delay = entityBlock.match(/^    delay: (-?\d+)$/m)?.[1] || null;
  const headsign = entityBlock.match(/^      tripHeadsign: "([^"]+)"$/m)?.[1];

  // Step 3: Extract each individual stop_time_update block using explicit 4-space indent limits
  const stopMatches = Array.from(
    entityBlock.matchAll(/^    stop_time_update \{([\s\S]*?)\n    \}/gm),
  );

  // Step 4: Parse individual fields out of each stop block using strict spacing
  const stops = stopMatches.map((stopMatch, stopIndex) => {
    const stopBlock = stopMatch[1];

    const stopId = stopBlock.match(/^      stop_id: "([^"]+)"$/m)![1];
    const arrival = stopBlock.match(/^      arrival \{\n\s+time: (\d+)\n\s+\}$/m)?.[1] || null;
    const departure = stopBlock.match(/^      departure \{\n\s+time: (\d+)\n\s+\}$/m)?.[1] || null;

    return {
      stopId,
      arrival: arrival ? Number(arrival) : null,
      departure: departure ? Number(departure) : null,
    };
  });

  return {
    entityId,
    tripId,
    scheduleRelationship: relationship,
    routeId,
    vehicleId,
    timestamp: Number(timestamp),
    delay: delay ? Number(delay) : null,
    tripHeadsign: headsign,
    stops,
  };
});

const tripUpdatesAtStop = tripUpdatesParsed
  .reduce(
    (acc, tu) => {
      for (const stop of tu.stops) {
        if (stop.stopId == '1_10912') {
          const inferredTrip = stopData.data.references.trips.find((t) => t.id == tu.tripId)!;
          const ad = stopData.data.entry.arrivalsAndDepartures.find((t) => t.tripId == tu.tripId)!;
          acc.push({
            route: inferredTrip.routeId,
            headsign: inferredTrip.tripHeadsign,
            lastLocationUpdateTime: ad.tripStatus.lastLocationUpdateTime,
            midway: ad.tripStatus.activeTripId == ad.tripId,
            at: new Date((stop.arrival || stop.departure) * 1000),
            timestamp: new Date(tu.timestamp * 1000),
          });
        }
      }
      return acc;
    },
    [] as {
      route: string;
      headsign: string;
      lastLocationUpdateTime: number;
      midway: boolean;
      at: Date;
      timestamp: Date;
    }[],
  )
  .toSorted((a, b) => a.at.getTime() - b.at.getTime());

const gn = tripUpdatesAtStop.length;
const gnLocation = tripUpdatesAtStop.filter((u) => u.lastLocationUpdateTime).length;
const gnLocationAndSoon = tripUpdatesAtStop.filter(
  (u) => u.lastLocationUpdateTime && u.at.getTime() < anchorTime.getTime() + 1000 * 60 * 60,
).length;
const gnMidway = tripUpdatesAtStop.filter((u) => u.lastLocationUpdateTime && u.midway).length;
---

<BlogPost {title} {date}>
  <link rel="preload" href={redactedScript} as="font" type="font/woff2" crossorigin />
  <p>
    When I took Sound Transit this summer, it often gave me a "realtime" ETA of 0 minutes when the
    bus was 4 minutes away. But how did it end up being displayed as realtime? Long story that
    starts with
  </p>
  <a href="https://opentransitsoftwarefoundation.org/onebusaway/" class="oba not-prose layer">
    <img {...obaLogo} alt="" />
    <p><strong>OneBusAway</strong></p>
    <p>A Sound Transit wrapper. Founded 2008, written in Java, comes from UW.</p>
    <p>
      Want Sound Transit data? You'll need to use their API - auth in (you can use <code>TEST</code> or
      steal <code>soundtransit.org</code>'s (yes even <code>soundtransit.org</code> relies on OneBusAway))
      and parse (choose from JSON or GTFS-RT protobuf). Let's try it.
    </p>
  </a>
  <section class="api-call">
    <p class="get">GET</p>
    <p class="url">
      https://api.pugetsound.onebusaway.org/api/where/arrivals-and-departures-for-stop/<abbr
        title="15th Ave NE & NE 43rd St">1_10912.json</abbr
      >?key=<span class="redacted">00000000-0000-0000-0000-000000000000</span>&minutesAfter=240
    </p>
    {
      arrivalsAndDepartures.map((ad) => (
        <p class="arrival-departure">
          <Route id={ad.routeId} /> to {ad.tripHeadsign}
          <span style="flex-grow:1" />
          {ad.predicted && ad.predictedArrivalTime ? (
            <>
              <span
                style={{
                  display: 'contents',
                  color:
                    ad.predictedArrivalTime > ad.scheduledArrivalTime
                      ? '#fd7e94'
                      : ad.predictedArrivalTime < ad.scheduledArrivalTime
                        ? '#90ffb3'
                        : undefined,
                }}
                title={`adjusted ${Math.round((ad.predictedArrivalTime - ad.scheduledArrivalTime) / 1000)}s`}
              >
                {relativeTime(new Date(ad.predictedArrivalTime))}
                <Pulser />
              </span>
              <span class="small">from {relativeTime(new Date(ad.lastUpdateTime))}</span>
            </>
          ) : (
            <>schedule: {relativeTime(new Date(ad.scheduledArrivalTime))}</>
          )}
          {ad.tripStatus.lastLocationUpdateTime &&
          ad.tripStatus.lastLocationUpdateTime == ad.lastUpdateTime &&
          ad.tripStatus.activeTripId == ad.tripId ? (
            <abbr class="small" title="live location">
              📍
            </abbr>
          ) : undefined}
          {ad.tripStatus.lastLocationUpdateTime &&
          ad.tripStatus.lastLocationUpdateTime == ad.lastUpdateTime &&
          ad.tripStatus.activeTripId != ad.tripId ? (
            <abbr class="small" title="this trip hasn't started yet">
              🔜
            </abbr>
          ) : undefined}
          {!ad.tripStatus.lastLocationUpdateTime ? (
            <abbr class="small" title="no location">
              ❌
            </abbr>
          ) : undefined}
        </p>
      ))
    }
  </section>
  <p>
    <Percent v={jnPredicted / jn} />
    {((jnPredicted / jn) * 100).toFixed(1)}% ({jnPredicted} vs {jn - jnPredicted}) have <code
      >predicted: true</code
    >
    <Pulser />
    (with <Percent v={jnPredictedMeaningfully / jnPredicted} />
    {jnPredictedMeaningfully} actually deviating from schedule). But only <Percent
      v={jnPredictedAndLocation / jnPredicted}
    />
    {jnPredictedAndLocation} predictions are based on a location; from there, <Percent
      v={jnPredictedAndLocationAndSoon / jnPredictedAndLocation}
    />
    {jnPredictedAndLocationAndSoon} could be accurate (within an hour); from there, <Percent
      v={jnPredictedAndMidway / jnPredictedAndLocationAndSoon}
    />
    {jnPredictedAndMidway} are likely 📍 accurate (bus already running the trip in question).
  </p>
  <p>
    Let's view the same data, but instead of using OneBusAway's JSON, use their GTFS-RT, and see
    what changes.
  </p>
  <section class="api-call">
    <p class="get">GET</p>
    <p class="url">
      https://api.pugetsound.onebusaway.org/api/gtfs_realtime/trip-updates-for-agency/<abbr
        title="like 1 or 40">[id]</abbr
      >.pbtext?key=<span class="redacted">00000000-0000-0000-0000-000000000000</span
      >&removeAgencyIds=false
    </p>
    {
      tripUpdatesAtStop.map((x) => (
        <p class="arrival-departure">
          <Route id={x.route} />
          to {x.headsign}
          <span style="flex-grow:1" />
          {relativeTime(x.at)}
          <span class="small">from {relativeTime(x.timestamp)}</span>
        </p>
      ))
    }
  </section>
  <p>
    It turns out that the GTFS-RT has only {gn} ETAs at <abbr title="15th Ave NE & NE 43rd St"
      >this stop</abbr
    >. But the GTFS-RT is the ground truth. The GTFS-RT doesn't go beyond "{
      relativeTime(tripUpdatesAtStop.at(-1)!.at)
    }" because we actually don't have data beyond that. So we've just found a bug with OneBusAway's
    JSON API:
  </p>
  <div class="stack-two not-prose">
    <a class="layer" href="https://github.com/OneBusAway/onebusaway-application-modules/issues/216">
      <h2>
        Delay is appearing on all trip of vehicle and trip repeating multiple times <span
          class="small">Issue #216</span
        >
      </h2>
      <p>
        "this trip is showing twice in list, and all other trips are carrying the same delay value
        even we didn't delay on those trips"
      </p>
    </a>
    <a class="layer" href="https://github.com/OneBusAway/onebusaway-application-modules/pull/465">
      <h2>Fix block-level cache contamination <span class="small">PR #465</span></h2>
      <p>
        "if <em>any</em> trip on a block had GTFS‑RT data, the cache returned a non‑empty location list,
        and <code>predicted=true</code> leaked to every trip on that block even if they had no RT data."
      </p>
    </a>
  </div>
  <br />
  <p>
    So we've found out that <Percent v={(jnPredicted - gn) / jnPredicted} />
    {(((jnPredicted - gn) / jnPredicted) * 100).toFixed(1)}% of ETAs are junk and don't exist in the
    upstream GTFS-RT. But is it just {(((jnPredicted - gn) / jnPredicted) * 100).toFixed(1)}%, or
    are there more junk ETAs?
  </p>
  <div class="stack-two">
    <input class="prediction" placeholder="enter your prediction here" />
    <div>
      <p>
        <em>While you make a prediction, some fun facts:</em>
      </p>
      <p>Sound Transit's location data is much better than their ETA data.</p>
      <p>Sound Transit's ETAs are accurate to the second at the start of the day.</p>
      <p>
        Even though <code>soundtransit.org</code> fetches the next 4 hours' ETAs, it only uses the next
        hour's data.
      </p>
      <p>
        That GTFS-RT table had to cross reference with the JSON to include line info, because
        OneBusAway has another bug (will be fixed by <a
          href="https://github.com/OneBusAway/onebusaway-application-modules/pull/466">#466</a
        >) that drops <code>route_id</code> from its GTFS-RT for everything but current trips.
      </p>
    </div>
  </div>
  <br />
  <p>
    If you said there are more junk ETAs, you're right. Think about it - how could an ETA more than
    an hour out possibly be accurate? Within GTFS-RT, just <Percent v={gnLocation / gn} />
    {gnLocation} ETAs are based on a location; from there, <Percent
      v={gnLocationAndSoon / gnLocation}
    />
    {gnLocationAndSoon} could be accurate (within an hour); from there, <Percent
      v={gnMidway / gnLocationAndSoon}
    />
    {gnMidway} are likely accurate (bus already running the trip in question).
  </p>
  <p>
    In other terms, <Percent v={(jn - gnMidway) / jn} />
    {(((jn - gnMidway) / jn) * 100).toFixed(1)}% of ETAs might be junk, and <Percent
      v={(jn - gnLocation) / jn}
    />
    {(((jn - gnLocation) / jn) * 100).toFixed(1)}% of ETAs are junk. Our only recourse is to get
    Sound Transit to fix <em>their</em> GTFS-RT feed to not include ETAs when they aren't actually realtime.
    And this fix is a two parter:
  </p>
  <div class="stack-two not-prose">
    <details>
      <summary
        >Generate and email Sound Transit a technical explanation of why/how to use <code
          >NO_DATA</code
        > when they don't have enough information to predict a realtime ETA</summary
      >
      <p>
        Sound Transit's GTFS-RT feed copies static schedule times into <code>stop_time_update</code
        >'s <code>arrival</code> and <code>departure</code>
        <code>time</code> fields for trips where the vehicle hasn't started the route yet. This makes
        those
        <code>stop_time_update</code> blocks indistinguishable from actual real-time predictions. The
        spec provides <code>NO_DATA</code> for exactly this situation — it means "no real-time timing
        available, use the static schedule."
      </p>

      <h2>Current behavior</h2>
      <p>Many TripUpdates in the feed look like this:</p>

      <pre>{`trip_update {
trip {
  trip_id: "605627320"
  schedule_relationship: SCHEDULED
}
stop_time_update {
  arrival { time: 1783035360 }     # ← copied from static GTFS
  departure { time: 1783035360 }   # ← copied from static GTFS
  stop_id: "LS23561"
}
stop_time_update {
  arrival { time: 1783035585 }
  departure { time: 1783035585 }
  stop_id: "38567"
}
# ... 14 more stops with copied times ...
vehicle { id: "8096168" }
timestamp: 1783035094
}`}</pre>

      <p>
        There's no <code>route_id</code>, no <code>delay</code> field, and no explicit <code
          >schedule_relationship</code
        > on the <code>stop_time_update</code> entries (they default to <code>SCHEDULED</code>). The
        vehicle hasn't started this trip yet — in many cases it's still finishing a previous trip in
        the block, or it's not broadcasting position at all.
      </p>

      <p>
        The <code>time</code> values in <code>arrival</code> and <code>departure</code> are exact copies
        of the static GTFS schedule. They are never anything else. A trip that's 40+ minutes from departure
        shows the same schedule times as a trip that's actively being tracked and running on time. There
        is no way to tell them apart by looking at the <code>stop_time_update</code> alone.
      </p>

      <p>
        This isn't just optimistic extrapolation — it's wrong. The GTFS-RT spec says a populated <code
          >time</code
        > field in a <code>StopTimeEvent</code> means "prediction available." A schedule copy is not a
        prediction. Any consumer — Google Maps, Transit App, OneBusAway — will interpret these schedule
        echoes as real-time ETAs and display them with real-time indicators.
      </p>

      <h2>What the spec provides: <code>NO_DATA</code></h2>
      <p>The <code>StopTimeUpdate.schedule_relationship</code> enum includes:</p>

      <blockquote>
        <strong><code>NO_DATA</code></strong> — "No real-time data is given for this stop. It indicates
        that there is no realtime timing information available. When set <code>NO_DATA</code> is propagated
        through subsequent stops so this is the recommended way of specifying from which stop you do not
        have realtime timing information."
      </blockquote>

      <p>And <code>StopTimeEvent</code> says:</p>

      <blockquote>
        <code>time</code> — "<strong>Forbidden</strong> if StopTimeUpdate.schedule_relationship is NO_DATA."
      </blockquote>

      <p>The correct representation for a trip that hasn't started yet is:</p>

      <pre>{`trip_update {
  trip {
    trip_id: "605627320"
    schedule_relationship: SCHEDULED
  }
  vehicle { id: "8096168" }
  timestamp: 1783035094
  stop_time_update {
    schedule_relationship: NO_DATA
    stop_id: "LS23561"
  }
}`}</pre>

      <p>This says:</p>
      <ul>
        <li>
          <strong>Trip exists, vehicle is assigned</strong> — the TripUpdate and <code>vehicle</code
          > field remain
        </li>
        <li><strong>No real-time timing available</strong> — <code>NO_DATA</code> on the stops</li>
        <li>
          <strong>Consumer should use the static GTFS for schedule times</strong> — which they already
          have and merge by design
        </li>
      </ul>

      <p>
        Only one <code>NO_DATA</code> stop is needed per trip — the spec says it propagates to all subsequent
        stops automatically.
      </p>

      <h2>Current feed statistics</h2>
      <table>
        <thead>
          <tr>
            <th>Category</th>
            <th>Count</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Active TripUpdates (has route_id, has delay field)</td>
            <td>162</td>
            <td>Vehicle is being tracked — these are correct</td>
          </tr>
          <tr>
            <td><strong>Schedule stubs (no route_id, no delay, schedule times copied)</strong></td>
            <td><strong>71</strong></td>
            <td
              ><strong
                >These are the problem — vehicle hasn't started the trip, times are fake predictions</strong
              ></td
            >
          </tr>
          <tr>
            <td style="padding-left: 20px;"
              >Of which: vehicle is actively tracked on a different trip (same block)</td
            >
            <td>20</td>
            <td
              >Vehicle is currently elsewhere; will serve this trip next. Still no ETA for this trip
              yet.</td
            >
          </tr>
          <tr>
            <td style="padding-left: 20px;">Of which: vehicle is not currently tracked anywhere</td>
            <td>51</td>
            <td
              >Vehicle ID is known but not broadcasting position. Assignment may be speculative.</td
            >
          </tr>
        </tbody>
      </table>

      <h2>My request</h2>
      <p>
        For every <code>stop_time_update</code> on a trip where the vehicle hasn't actually started that
        trip yet, replace the current pattern (schedule times in <code>arrival</code>/<code
          >departure</code
        >, implicit <code>SCHEDULED</code>) with:
      </p>

      <pre>{`stop_time_update {
  schedule_relationship: NO_DATA
  stop_id: "..."
}`}</pre>

      <ul>
        <li>
          Keep the TripUpdate as a whole + its <code>vehicle</code> field — consumers should still know
          which bus is assigned
        </li>
        <li>Keep the TripUpdate's <code>trip_id</code> — the trip exists</li>
        <li>
          Drop the schedule times from <code>arrival</code>/<code>departure</code> — they aren't predictions
        </li>
        <li>
          When the vehicle actually starts the trip, populate the real <code>arrival</code>/<code
            >departure</code
          > with <code>SCHEDULED</code> + <code>time</code>, set <code>route_id</code> on the <code
            >trip</code
          >, and include a <code>delay</code> field (as the feed already does for active trips)
        </li>
      </ul>

      <p>
        Static GTFS already provides the schedule. GTFS-RT should only provide data that improves on
        it. Schedule copies do not improve on it — they actively mislead consumers into thinking
        real-time predictions exist when they don't.
      </p>

      <p>
        <em
          >Observed on the live trip-updates feed at
          <a
            href="http://api.pugetsound.onebusaway.org/api/gtfs_realtime/trip-updates-for-agency/40.pb"
            target="_blank"
            rel="noopener noreferrer"
            >api.pugetsound.onebusaway.org/api/gtfs_realtime/trip-updates-for-agency/40.pb</a
          >.
        </em>
      </p>
    </details>
    <a class="layer" href="https://github.com/OneBusAway/onebusaway-application-modules/pull/467">
      <h2>
        Passthrough NO_DATA schedule_relationship for stop_time_updates <span class="small"
          >PR #467</span
        >
      </h2>
      <p>"Passthrough schedule_relationship value directly instead of hardcoding SCHEDULED"</p>
    </a>
  </div>

  <br />
  <p>The only thing left to do is wait on SoundTransit and OneBusAway.</p>

  <style>
    .oba {
      display: grid;
      grid-template-columns: 4rem 1fr;
      grid-template-rows: auto auto auto;
      align-items: center;

      background-color: var(--m3c-surface-container);
      padding: 0.5rem;
      gap: 0.5rem;
      border-radius: 1rem;
    }
    .oba > img {
      grid-row: 1 / -1;
    }
    .oba > p {
      grid-column: 2;
    }
    .api-call {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 0.5rem;
      max-height: 20rem;
      overflow: auto;
    }
    .get {
      display: flex;
      align-items: center;
      background-color: var(--m3c-primary-container);
      color: var(--m3c-on-primary-container);
      padding-inline: 0.25rem;
      border-radius: 0.5rem;
      border-top-left-radius: 1rem;
      font-family: monospace;
    }
    .url {
      background-color: var(--m3c-surface-container);
      padding-inline: 0.25rem;
      border-radius: 0.5rem;
      border-top-right-radius: 1rem;
      font-family: monospace;
    }
    .arrival-departure {
      display: flex;
      grid-column: 1 / -1;
      gap: 0.25rem;
      background-color: var(--m3c-surface-container);
      padding-inline-end: 0.25rem;
      border-radius: 0.5rem;
    }
    .redacted {
      font-family: 'Redacted Script';
    }
    .small {
      font-size: 0.75em;
      opacity: 0.75;
    }
    .stack-two {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.5rem;
      > * {
        display: flex;
        flex-direction: column;
        background-color: var(--m3c-primary-container);
        color: var(--m3c-on-primary-container);
        gap: 1rem;
        padding: 0.5rem;
        border-radius: 1rem;
        > h2 {
          font-size: 1.5rem;
          line-height: 1;
        }
      }
    }
    .prediction {
      background-color: var(--m3c-surface-container);
      width: 100%;
      padding-inline: 0.5rem;
      border-radius: 1rem;
    }
  </style>
</BlogPost>
