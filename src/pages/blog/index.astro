---
import Base from '$lib/layouts/Base.astro';
import Header from '$lib/Header.astro';
import { blogPosts } from 'virtual:post-lists';
---

<Base title="Blog">
  <Header />

  <main>
    {
      blogPosts.map(({ title, link, length }) => (
        <a class="layer" href={link} style={`--length:${length}`}>
          {title}
        </a>
      ))
    }
  </main>
</Base>

<style>
  main {
    display: flex;
    flex-wrap: wrap;
    margin: 1.5rem;
    gap: 0.5rem;
    flex-grow: 1;
  }
  a {
    flex: 1 1 8rem;
    border-radius: 1rem;
    padding: 1rem;
    background-color: var(--m3c-surface-container-low);
    position: relative;
    @media (width >= 40rem) {
      min-width: min(32rem, calc(var(--length) * 0.1px));
    }
  }
</style>
