---
import gtfsrt from 'gtfs-realtime-bindings';
import { readFile } from 'node:fs/promises';
import BlogPost from '$lib/layouts/BlogPost.astro';

import jsonOBA from './data/oba.json';
import jsonTransit from './data/transit.json';
import logoTransit from './logo-transit.svg';
import logoST from './logo-soundtransit.svg';
import logoKing from './logo-king.svg';
import logoOBAYellow from './logo-oba-yellow.svg';
import logoOBA from './logo-oba.svg';
import Percent from './_Percent.astro';
import Pulser from './_Pulser.astro';
import Route from './_Route.astro';

export const title = 'Ghost Buses Incorporated';
export const date = '2026-07-03';

const {
  transit_realtime: { FeedMessage },
} = gtfsrt;

// pi --session 019f2ade-29bc-755b-bbbd-ab2c326a63e5
const routesKingCSV = (await readFile('src/pages/blog/ghostbuses/data/routes.txt', 'utf-8'))
  .replaceAll('\r', '')
  .split('\n');
const routesKingCols = routesKingCSV[0].split(',');
const routesKing = routesKingCSV.slice(1).map((line) => {
  const data: Record<string, any> = {};
  const cells = line.split(',');
  for (let i = 0; i < cells.length; i++) {
    let cell = cells[i];
    if (cell.startsWith('"') && cell.endsWith('"')) cell = cell.slice(1, -1);
    const col = routesKingCols[i];
    data[col] = cell;
  }
  return data;
});
const tripsKingCSV = (await readFile('src/pages/blog/ghostbuses/data/trips.txt', 'utf-8'))
  .replaceAll('\r', '')
  .split('\n');
const tripsKingCols = tripsKingCSV[0].split(',');
const tripsKing = tripsKingCSV.slice(1).map((line) => {
  const data: Record<string, any> = {};
  const cells = line.split(',');
  for (let i = 0; i < cells.length; i++) {
    let cell = cells[i];
    if (cell.startsWith('"') && cell.endsWith('"')) cell = cell.slice(1, -1);
    const col = tripsKingCols[i];
    data[col] = cell;
  }
  return data;
});
const rtKing = FeedMessage.decode(
  new Uint8Array(await readFile('src/pages/blog/ghostbuses/data/king.tripupdates.pb')),
);
const rtOBA = FeedMessage.decode(
  new Uint8Array(await readFile('src/pages/blog/ghostbuses/data/oba.tripupdates.pb')),
);
const rtKingVP = FeedMessage.decode(
  new Uint8Array(await readFile('src/pages/blog/ghostbuses/data/king.vehiclepositions.pb')),
);
const rtOBAVP = FeedMessage.decode(
  new Uint8Array(await readFile('src/pages/blog/ghostbuses/data/oba.vehiclepositions.pb')),
);

const anchorTime = new Date('Sat Jul  4 10:08:08 AM PDT 2026');
const relativeTime = (date: Date) => {
  const seconds = (date.getTime() - anchorTime.getTime()) / 1000;
  const magnitude = Math.abs(seconds);
  const magnitudeRound = Math.round(magnitude);
  const str = magnitudeRound >= 100 ? `${Math.round(magnitude / 60)}m` : `${magnitudeRound}s`;
  return seconds >= 0 ? `in ${str}` : `${str} ago`;
};

// --- Lookups ---

function tripFromGtfs(tripId: string) {
  return tripsKing.find((t) => t.trip_id === tripId) ?? null;
}

// --- GTFS stop_times: scheduled departure for stop 10914 (used by king source) ---
const anchorLocal = anchorTime.toLocaleTimeString('en-US', {
  timeZone: 'America/Los_Angeles',
  hour12: false,
});
const anchorHMS = anchorLocal
  .split(':')
  .map(Number)
  .reduce((a, b) => a * 60 + b);
const anchorMidnight = Math.round(anchorTime.getTime() / 1000) - anchorHMS;
const schedAt10914: Record<string, number> = {};
for (const line of (await readFile('src/pages/blog/ghostbuses/data/stop_times.txt', 'utf-8'))
  .replaceAll('\r', '')
  .split('\n')
  .slice(1)) {
  if (!line) continue;
  const c = line.split(',');
  if (c[3] !== '10914') continue;
  const [h, m, s] = c[2].split(':').map(Number);
  schedAt10914[c[0]] = (anchorMidnight + h * 3600 + m * 60 + (s || 0)) * 1000;
}

// --- King vehicle positions: vehicleId → vehicle ---
const kingVpByVeh: Record<string, any> = {};
for (const e of rtKingVP.entity) {
  const v = e.vehicle;
  if (!v) throw new Error('king VP: entity without vehicle');
  const vid = v.vehicle?.id;
  if (vid) kingVpByVeh[vid] = v;
}

// --- OBA vehicle positions: vehicleId → vehicle ---
const obaVpByVeh: Record<string, any> = {};
for (const e of rtOBAVP.entity) {
  const v = e.vehicle;
  if (!v) throw new Error('oba VP: entity without vehicle');
  const vid = v.vehicle?.id;
  if (vid) obaVpByVeh[vid] = v;
}

type MegaEntry = {
  time: number;
  source: 'king' | 'oba-rt' | 'oba-json' | 'transit';
  route: { id: string; short: string; headsign: string; bg: string; fg: string };
  vid: string | null;
  hasLive: boolean | null;
  currentTripId: string | null;
  lastUpdated: number | null;
  scheduledTime: number | null;
};

const megaMap: Record<string, MegaEntry[]> = {};

function hasLivePos(v: any): boolean {
  return !!(v?.position && (v.position.latitude !== 0 || v.position.longitude !== 0));
}

function routeFromGtfs(routeId: string): MegaEntry['route'] | null {
  const r = routesKing.find((x) => x.route_id == routeId);
  if (!r) return null;
  return {
    id: routeId,
    short: r.route_short_name,
    bg: '#' + r.route_color,
    fg: '#' + r.route_text_color,
    headsign: '',
  };
}

// --- OBA JSON references: build route lookup from its own data ---
const obaRouteRef: Record<string, { id: string; short: string; bg: string; fg: string }> = {};
for (const r of jsonOBA.data.references.routes) {
  obaRouteRef[r.id.replace(/^\d+_/, '')] = {
    id: r.id.replace(/^\d+_/, ''),
    short: r.shortName,
    bg: '#' + r.color,
    fg: '#' + r.textColor,
  };
}

// --- 1. Source: king (King County GTFS-RT trip updates + vehicle positions) ---
for (const e of rtKing.entity) {
  const tu = e.tripUpdate;
  if (!tu) throw new Error('king: entity without tripUpdate');
  const stop = tu.stopTimeUpdate?.find((s: any) => s.stopId === '10914');
  if (!stop) continue;
  const time = Number(stop.departure?.time ?? stop.arrival?.time ?? 0) * 1000;
  if (!time) throw new Error('king: missing departure time');
  const tripId = tu.trip.tripId;
  if (!tripId) throw new Error('king: missing tripId');
  const routeId = tu.trip.routeId;
  if (!routeId) throw new Error('king: missing routeId');
  if (routesKing.find((r) => r.route_id === routeId)?.agency_id !== '1') continue;
  const base = routeFromGtfs(routeId);
  if (!base) throw new Error('king: route not found: ' + routeId);
  base.headsign = tripFromGtfs(tripId)?.trip_headsign ?? '';
  const vid = tu.vehicle?.id || null;
  const vp = vid ? kingVpByVeh[vid] : null;
  const hasLive = !!(vp && hasLivePos(vp));
  const currentTripId = hasLive ? (vp.trip?.tripId ?? null) : null;
  if (!megaMap[tripId]) megaMap[tripId] = [];
  megaMap[tripId].push({
    time,
    source: 'king',
    route: base,
    vid,
    hasLive,
    currentTripId,
    lastUpdated: (Number(tu.timestamp) || null) && Number(tu.timestamp) * 1000,
    scheduledTime: schedAt10914[tripId] ?? null,
  });
}

// --- 2. Source: oba-rt (OneBusAway GTFS-RT trip updates + vehicle positions) ---
for (const e of rtOBA.entity) {
  const tu = e.tripUpdate;
  if (!tu) throw new Error('oba-rt: entity without tripUpdate');
  const stop = tu.stopTimeUpdate?.find((s: any) => s.stopId === '10914');
  if (!stop) continue;
  const time = Number(stop.departure?.time ?? stop.arrival?.time ?? 0) * 1000;
  if (!time) throw new Error('oba-rt: missing departure time');
  const tripId = tu.trip.tripId;
  if (!tripId) throw new Error('oba-rt: missing tripId');
  let routeId = tu.trip.routeId;
  if (!routeId) {
    const t = tripFromGtfs(tripId);
    if (t) routeId = t.route_id;
  }
  if (!routeId) throw new Error('oba-rt: missing routeId for trip ' + tripId);
  const base = routeFromGtfs(routeId);
  if (!base) throw new Error('oba-rt: route not found: ' + routeId);
  base.headsign = tripFromGtfs(tripId)?.trip_headsign ?? '';
  const vehId = tu.vehicle?.id ?? null;
  const vp = vehId ? obaVpByVeh[vehId] : null;
  const hasLive = !!(vp && hasLivePos(vp));
  const currentTripId = vp?.trip?.tripId ?? null;
  if (!megaMap[tripId]) megaMap[tripId] = [];
  megaMap[tripId].push({
    time,
    source: 'oba-rt',
    route: base,
    vid: vehId,
    hasLive,
    currentTripId,
    lastUpdated: (Number(tu.timestamp) || null) && Number(tu.timestamp) * 1000,
    scheduledTime: null,
  });
}

function agency1(id: string): string {
  if (!id.startsWith('1_')) throw new Error('oba-json: expected agency 1, got: ' + id);
  return id.slice(2);
}

// --- 3. Source: oba-json (OneBusAway REST API, uses its own tripStatus) ---
for (const a of jsonOBA.data.entry.arrivalsAndDepartures) {
  if (!a.predicted) continue;
  if (!a.routeId.startsWith('1_')) continue;
  const timeMs = a.predictedDepartureTime;
  if (!timeMs) throw new Error('oba-json: missing predictedDepartureTime for trip ' + a.tripId);
  const time = timeMs;
  const tripId = agency1(a.tripId);
  const headsign = a.tripHeadsign;

  const rawRouteId = agency1(a.routeId);
  const ref = obaRouteRef[rawRouteId];
  if (!ref) throw new Error('oba-json: route not found in references: ' + rawRouteId);
  const route: MegaEntry['route'] = { ...ref, headsign };

  const vid = a.vehicleId ? agency1(a.vehicleId) : null;
  const ts = a.tripStatus;
  const hasLive = (ts?.lastLocationUpdateTime ?? 0) > 0;
  const currentTripId = ts?.activeTripId ? agency1(ts.activeTripId) : null;
  if (!megaMap[tripId]) megaMap[tripId] = [];
  megaMap[tripId].push({
    time,
    source: 'oba-json',
    route,
    vid,
    hasLive,
    currentTripId,
    lastUpdated: a.lastUpdateTime || null,
    scheduledTime: a.scheduledDepartureTime ?? null,
  });
}

// --- 4. Source: transit (Transit app, no vehicle data) ---
for (const rd of jsonTransit.route_departures) {
  for (const mi of rd.merged_itineraries) {
    const route: MegaEntry['route'] = {
      id: rd.real_time_route_id,
      short: rd.route_short_name,
      bg: '#' + rd.route_color,
      fg: '#' + rd.route_text_color,
      headsign: mi.itineraries[0]?.headsign ?? '',
    };
    for (const si of mi.schedule_items) {
      if (!si.is_real_time) continue;
      const time = si.departure_time * 1000;
      if (!time) throw new Error('transit: missing departure_time');
      const tripId = si.rt_trip_id;
      if (!megaMap[tripId]) megaMap[tripId] = [];
      megaMap[tripId].push({
        time,
        source: 'transit',
        route,
        vid: null,
        hasLive: null,
        currentTripId: null,
        lastUpdated: null,
        scheduledTime: (si.scheduled_departure_time ?? 0) * 1000 || null,
      });
    }
  }
}
const megaMapFlat = Object.entries(megaMap).sort(
  ([, a], [, b]) => Math.min(...a.map((e) => e.time)) - Math.min(...b.map((e) => e.time)),
);
const n = megaMapFlat.length;
const nWithJustOBAJSON = megaMapFlat.filter(
  ([, entries]) => entries.length == 1 && entries.some((e) => e.source == 'oba-json'),
).length;
const nKCWithVID = megaMapFlat.filter(([, entries]) =>
  entries.some((e) => e.source == 'king' && e.vid),
).length;
const nKCInferrableVID = megaMapFlat.filter(
  ([, entries]) =>
    entries.some((e) => e.source == 'king' && !e.vid) &&
    entries.some((e) => e.source == 'oba-rt' && e.vid?.length == 4),
).length;
const nKCNoVID = megaMapFlat.filter(
  ([, entries]) =>
    entries.some((e) => e.source == 'king' && !e.vid) &&
    entries.some((e) => e.source == 'oba-rt' && e.vid?.length != 4),
).length;
const nKCAdjusted = megaMapFlat.filter(([, entries]) => {
  const kc = entries.find((e) => e.source == 'king');
  if (!kc) return;
  return kc.scheduledTime != kc.time;
}).length;
const nKCAdjustedWithVID = megaMapFlat.filter(([, entries]) => {
  const kc = entries.find((e) => e.source == 'king');
  if (!kc) return;
  if (!kc.vid) return;
  return kc.scheduledTime != kc.time;
}).length;
---

<BlogPost {title} {date}>
  <div class="etas">
    {
      megaMapFlat.map(([tripId, entries]) => (
        <>
          <p style={{ marginTop: '0.5em' }}>
            <Route {...entries[0].route} />
            <span class="small">
              route #{entries[0].route.id}
              trip #{tripId}
            </span>
          </p>
          {entries.map((e) => (
            <p>
              {e.source == 'king' ? (
                <img
                  {...logoKing}
                  alt="King County Metro"
                  title="King County Metro"
                  style={{
                    display: 'inline-block',
                    width: '1em',
                    height: '1em',
                    verticalAlign: 'middle',
                  }}
                />
              ) : e.source == 'oba-rt' ? (
                <img
                  {...logoOBAYellow}
                  alt="OneBusAway GTFS-RT"
                  title="OneBusAway GTFS-RT"
                  style={{
                    display: 'inline-block',
                    width: '1em',
                    height: '1em',
                    verticalAlign: 'middle',
                  }}
                />
              ) : e.source == 'oba-json' ? (
                <img
                  {...logoOBA}
                  alt="OneBusAway JSON"
                  title="OneBusAway JSON"
                  style={{
                    display: 'inline-block',
                    width: '1em',
                    height: '1em',
                    verticalAlign: 'middle',
                  }}
                />
              ) : (
                <img
                  {...logoTransit}
                  alt="Transit"
                  title="Transit"
                  style={{
                    display: 'inline-block',
                    width: '1em',
                    height: '1em',
                    verticalAlign: 'middle',
                  }}
                />
              )}
              <span
                style={{
                  display: 'contents',
                  color:
                    e.scheduledTime && e.time > e.scheduledTime
                      ? '#fd7e94'
                      : e.scheduledTime && e.time < e.scheduledTime
                        ? '#90ffb3'
                        : undefined,
                }}
                title={
                  e.scheduledTime
                    ? `adjusted ${Math.round((e.time - e.scheduledTime) / 1000)}s`
                    : undefined
                }
              >
                {relativeTime(new Date(e.time))}
              </span>
              {e.lastUpdated && (
                <span class="small"> as of {relativeTime(new Date(e.lastUpdated))}</span>
              )}
              {e.source != 'transit' && !e.vid && ' • ❌ no vehicle'}
              {e.vid &&
                !e.hasLive &&
                e.vid.length != 4 &&
                ` • 👻 ghost vehicle ${e.vid}${e.currentTripId ? ` on trip ${e.currentTripId}` : ''}`}
              {e.vid && e.hasLive && e.currentTripId == tripId && ` • ✅ vehicle ${e.vid} running`}
              {e.vid &&
                e.hasLive &&
                e.currentTripId != tripId &&
                ` • ⏰ vehicle ${e.vid} on other trip ${e.currentTripId}`}
              {/*<em>{JSON.stringify(e)}</em>*/}
            </p>
          ))}
        </>
      ))
    }
  </div>
  <p>
    These are ETAs for when <img
      {...logoKing}
      style={{ display: 'inline-block', width: '1em', height: '1em', verticalAlign: 'middle' }}
    /> King County Metro buses arrive at the stop <abbr title="ID 10914, or KCM:89363 on Transit"
      >15th Ave NE & NE 43rd St</abbr
    >. But instead of just using
    <a
      href="https://kingcounty.gov/en/dept/metro/rider-tools/mobile-and-web-apps#toc-developer-resources"
      ><img
        {...logoKing}
        style={{ display: 'inline-block', width: '1em', height: '1em', verticalAlign: 'middle' }}
      /> King County Metro's official GTFS + GTFS-RT</a
    >
    or
    <a href="https://developer.onebusaway.org/api/gtfs-realtime"
      ><img
        {...logoOBAYellow}
        style={{ display: 'inline-block', width: '1em', height: '1em', verticalAlign: 'middle' }}
      /> OneBusAway's GTFS-RT</a
    >
    or
    <a href="https://developer.onebusaway.org/api/where/methods/arrivals-and-departures-for-stop"
      ><img
        {...logoOBA}
        style={{ display: 'inline-block', width: '1em', height: '1em', verticalAlign: 'middle' }}
      /> OneBusAway's realtime ETAs</a
    >
    or
    <a href="https://transitapp.com/"
      ><img
        {...logoTransit}
        style={{ display: 'inline-block', width: '1em', height: '1em', verticalAlign: 'middle' }}
      /> Transit's realtime stop ETAs</a
    >, I've shown you all four at once. You might notice that they're different. That's the problem.
  </p>
  <p>
    How can we tell what's actually realtime? {nKCAdjusted} ETAs aren't the scheduled times, so they're
    definitely realtime<Pulser />. These {nKCAdjustedWithVID} are also linked to a vehicle. Overall, the
    ETAs split
    <Percent v={nKCWithVID / n} />
    {nKCWithVID} linked to a vehicle, <Percent v={nKCInferrableVID / n} />
    {nKCInferrableVID} vehicle can be inferred, and <Percent v={nKCNoVID / n} />
    {nKCNoVID} unlinked to a vehicle (so <img
      {...logoOBA}
      style={{
        display: 'inline-block',
        width: '1em',
        height: '1em',
        verticalAlign: 'middle',
      }}
    /> OBA makes up a 👻 ghost vehicle), while
    <Percent v={nWithJustOBAJSON / n} />
    {nWithJustOBAJSON} are a figment of <img
      {...logoOBA}
      style={{
        display: 'inline-block',
        width: '1em',
        height: '1em',
        verticalAlign: 'middle',
      }}
    /> OBA JSON's imagination.
  </p>
  <p>
    What can we do about this? I've sent a <a
      href="https://github.com/OneBusAway/onebusaway-application-modules/pull/465">PR</a
    > for the {nWithJustOBAJSON}
    <img
      {...logoOBA}
      style={{
        display: 'inline-block',
        width: '1em',
        height: '1em',
        verticalAlign: 'middle',
      }}
    /> OBA JSON cases already. And I've asked <img
      {...logoKing}
      style={{ display: 'inline-block', width: '1em', height: '1em', verticalAlign: 'middle' }}
    /> King County Metro + <img
      {...logoST}
      style={{ display: 'inline-block', width: '1.5em', height: '1em', verticalAlign: 'middle' }}
    /> Sound Transit and <a
      href="https://github.com/OneBusAway/onebusaway-application-modules/pull/467"
      >PRd to OneBusAway</a
    > so that the {nKCNoVID}-{nKCNoVID + nKCInferrableVID} "ETAs" can use <code>NO_DATA</code> instead
    of claiming to be realtime<Pulser /> via <code>SCHEDULED</code>. But from here, since this is an
    upstream data problem, the only thing to do is wait.
  </p>
</BlogPost>

<style>
  .small {
    font-size: 0.75em;
    opacity: 0.75;
  }
  .etas {
    display: flex;
    flex-direction: column;
    border: solid 1px var(--m3c-outline);
    padding: 0.5rem;
    border-radius: 1rem;
    height: 30rem;
    overflow: auto;
  }
</style>
